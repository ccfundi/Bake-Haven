<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/main"
    app:cardBackgroundColor="#FFFFFF"
    app:cardElevation="15dp"
    app:cardCornerRadius="20dp"
    android:layout_margin="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:orientation="vertical"
        android:padding="15dp"
        android:layout_height="match_parent">


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Make Payments"
            android:textSize="30sp"
            android:layout_marginTop="30dp"
            android:textAlignment="center"
            android:textColor="@color/white"
            android:background="@drawable/shape"
            android:layout_margin="20dp"
            android:padding="10dp"
            />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:id="@+id/product_photo"
            android:layout_margin="8dp"
            android:src="@drawable/image24"



            />

        <TextView
            android:id="@+id/product_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Product Name"
            android:textSize="20dp"
            android:fontFamily="sans-serif-condensed-light"
            android:textStyle="bold"
            android:textColor="#000000"
            />

        <TextView
            android:id="@+id/product_cost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:text="Ksh 0"
            android:textColor="#F60D0D"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/product_description"
            android:text="This is a great product with amazing features"
            android:textSize="16sp"
            android:textColor="#000000"
            android:fontFamily="sans-serif-condensed-light"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="10dp"
            />

        <EditText
            android:id="@+id/phone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter phone 254xxxxxxxxx"
            android:background="@drawable/edittext"
            android:fontFamily="sans-serif-condensed-light"
            android:inputType="phone"
            android:padding="12dp"

            android:layout_margin="0dp"

            />

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PAY NOW"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp"
            android:id="@+id/payment"
            android:backgroundTint="#7AD50A"
            android:layout_margin="30dp"
            />

    </LinearLayout>


</androidx.cardview.widget.CardView>